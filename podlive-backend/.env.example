# =============================================
# PodLive Backend - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file!
# =============================================

# PostgreSQL Database (Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets (use long random strings in production)
JWT_ACCESS_SECRET="your-strong-access-secret-here"
JWT_REFRESH_SECRET="your-strong-refresh-secret-here"

# Server Port
PORT=5005
MAX_UPLOAD_SIZE_BYTES=2147483648
UPLOAD_CHUNK_MAX_BYTES=33554432
HLS_SEGMENT_SECONDS=10

# Bunny Stream (video uploads and VOD streaming)
BUNNY_STREAM_LIBRARY_ID="your-bunny-stream-library-id"
BUNNY_STREAM_ACCESS_KEY="your-bunny-stream-library-api-key"
BUNNY_STREAM_CDN_HOSTNAME="vz-your-library-hostname.b-cdn.net"
# Optional
BUNNY_STREAM_COLLECTION_ID=""
BUNNY_STREAM_ENABLED_RESOLUTIONS="240p,360p,480p,720p,1080p"
BUNNY_STREAM_OUTPUT_CODECS="x264"
BUNNY_STREAM_STATUS_SYNC_ATTEMPTS=60
BUNNY_STREAM_STATUS_SYNC_INTERVAL_MS=30000

# Bunny Storage for LiveKit live HLS egress (better Bunny CDN/DNS for live playback)
# Create a Bunny Storage zone with S3 compatibility enabled.
BUNNY_STORAGE_REGION="sg"
BUNNY_STORAGE_ENDPOINT="https://sg-s3.storage.bunnycdn.com"
BUNNY_STORAGE_ZONE="your-bunny-storage-zone-name"
BUNNY_STORAGE_PASSWORD="your-bunny-storage-zone-password"
BUNNY_STORAGE_PUBLIC_URL="https://your-bunny-pull-zone-or-custom-domain"

# LiveKit Cloud (https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Optional fallback S3-compatible storage for LiveKit HLS egress only.
# If Bunny Storage variables are set, they are preferred.
# VOD/video uploads use Bunny Stream above.
S3_ENDPOINT="https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3"
S3_REGION="ap-south-1"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_BUCKET_NAME="your-bucket-name"
S3_PUBLIC_URL="https://YOUR_PROJECT.supabase.co/storage/v1/object/public/your-bucket"

# HLS Egress Recording (set to 'true' to enable background recording)
ENABLE_LIVEKIT_HLS_EGRESS=false
ENABLE_LIVEKIT_INGRESS=false
LIVE_HLS_SEGMENT_SECONDS=2
LIVEKIT_EGRESS_LAYOUT=grid
